  "shell_command_profiles": {
    "swift_app": "set -euo pipefail\n\ncd \"$WORKSPACE\"\ngit submodule sync --recursive\ngit submodule update --init --remote --recursive deploy_shell\n\nbash \"$WORKSPACE/deploy_shell/deploy_swift_app/remote_deploy_pipeline.sh\" --config \"$WORKSPACE/{{config_path}}\"",
